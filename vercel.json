{
  "buildCommand": "true",
  "installCommand": "npm install --omit=dev",
  "outputDirectory": "public",
  "framework": null,
  "functions": {
    "api/hotels-search.js": { "maxDuration": 25 },
    "api/cj-refresh.js":    { "maxDuration": 60 },
    "api/admin.js":         { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/results", "destination": "/results.html" },
    { "source": "/trip/:id", "destination": "/trip.html?id=:id" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/impressum", "destination": "/impressum.html" },
    { "source": "/dobrodosao", "destination": "/dobrodosao.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/admin?action=retry-failed-emails",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/admin?action=packages-health",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/admin?action=daily-firestore-export",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/admin?action=daily-review-report",
      "schedule": "0 7 * * *"
    }
  ]
}
