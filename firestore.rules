rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── PACKAGES (v7 schema, flight+hotel+return triples) ──
    // Public reads OK only for published; writes via Admin SDK only
    match /letto_packages/{id} {
      allow read: if resource.data.status in ['published_public', 'published_premium'];
      allow write: if false;
    }

    // ─── SUBSCRIBERS ────────────────────────────────────────
    // No public access. Admin SDK writes through server-side /api/*.
    // Client-side Firebase Auth not in use for v0.1 — all reads server-only.
    match /letto_subscribers/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ─── ADMIN ──────────────────────────────────────────────
    // For future custom-claim admin tools. Admin API routes use
    // Admin SDK and bypass rules regardless.
    match /letto_admin/{doc=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // ─── TELEGRAM EVENTS (internal audit log) ───────────────
    match /letto_telegram_events/{eventId} {
      allow read, write: if false;
    }

    // ─── PRICE HISTORY (used by n8n scanner) ────────────────
    match /letto_price_history/{docId} {
      allow read, write: if false;
    }

    // ─── MIX CACHE (Workflow 05 — flight+hotel search cache) ──
    // Backend (n8n + Admin SDK) writes; client reads not used in V0.1.
    match /mix_cache/{cacheId} {
      allow read, write: if false;
    }

    // ─── MIX SEARCHES (analytics, write-only from server) ───
    // Admin SDK only — bypasses rules. Client never touches.
    match /mix_searches/{searchId} {
      allow read, write: if false;
    }

    // ─── PENDING MIXES (C-1 · Mix kao proizvod) ─────────────
    // Snapshot of state.flight + state.hotel + searchParams written by
    // /api/stripe-checkout before the user is redirected to Stripe; cleared
    // by the webhook on payment success. Server-only.
    match /pendingMixes/{pendingMixId} {
      allow read, write: if false;
    }

    // ─── PURCHASED MIXES (C-1) ──────────────────────────────
    // Authoritative record of paid-for trips. Created by the Stripe webhook
    // after checkout.session.completed. Future C-2 emails the trip details
    // to userEmail. Server-only (client reads through Admin-SDK /api/me-mix).
    match /purchasedMixes/{tripId} {
      allow read, write: if false;
    }

    // ─── FAILED EMAIL SENDS (F13) ───────────────────────────
    // Webhook writes here when sendMixConfirmationEmail exhausts retries.
    // Daily Vercel cron + admin retry endpoint reprocess pending_retry rows.
    match /failed_email_sends/{tripId} {
      allow read, write: if false;
    }

    // ─── FAILED PURCHASES (F14/F18) ─────────────────────────
    // Webhook writes here when a paid Stripe session has no recoverable
    // customer email (Apple Pay / Express checkout edge). Manual recovery
    // through Stripe Dashboard.
    match /failed_purchases/{sessionId} {
      allow read, write: if false;
    }

    // ─── CURRENCY MISMATCHES (F46) ──────────────────────────
    // Webhook quarantines paid sessions whose currency != EUR before any
    // purchasedMixes / letto_subscribers write. Manual reconciliation only.
    match /currency_mismatches/{sessionId} {
      allow read, write: if false;
    }

    // ─── HOTELS SEARCH CACHE (FAZA H) ───────────────────────
    // 6h-TTL Firestore cache for /api/hotels-search RapidAPI results, keyed
    // by destinationIATA_checkIn_checkOut_adults_children. Server-side only;
    // client reads go through the API which validates auth/CORS.
    match /hotels_search_cache/{cacheKey} {
      allow read, write: if false;
    }

    // ─── DENY BY DEFAULT ────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
