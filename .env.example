# ═══════════════════════════════════════════════
# LETTO.LIVE — Environment Variables
# ═══════════════════════════════════════════════

# ─── Claude API ─────────────────────────────────
# Used for: blurb writing, NLP search parsing
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# ─── Stripe ─────────────────────────────────────
# Used for: Premium subscription checkout + webhooks
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
# LETTO Premium: €29 every 3 months, recurring
STRIPE_PREMIUM_PRICE_ID=price_xxxxx
# Beta coupon: €10 off (effective €19/3mo), max_redemptions=100
STRIPE_BETA_COUPON_ID=FIRST100

# Client-exposed (safe to use with VITE_ prefix)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx

# ─── Meta Conversions API (server-side Pixel · v28) ─
# Used for: Subscribe event from Stripe webhook · defeats ad-blockers,
#           recovers ~20-40% of attribution lost to client-side blocking
# Get from: business.facebook.com/events_manager → Pixel 2513952102382319
#           → Settings → Conversions API → Generate access token
# Without this set, lib/meta-capi.js sendCapiEvent() is a silent no-op
META_CAPI_ACCESS_TOKEN=EAAxxxxx
# Optional · routes events to Events Manager → Test Events tab without
# polluting production stats. Generate code in that tab.
META_CAPI_TEST_EVENT_CODE=

# ─── Firebase ───────────────────────────────────
# Used for: User data, subscription state, deal storage
# Get from: https://console.firebase.google.com/
# Reuse existing molty-portal or create new "letto-ai" project
VITE_FIREBASE_API_KEY=xxxxx
VITE_FIREBASE_AUTH_DOMAIN=letto-ai.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=letto-ai
VITE_FIREBASE_STORAGE_BUCKET=letto-ai.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=xxxxx
VITE_FIREBASE_APP_ID=1:xxxxx:web:xxxxx

# Server-side (admin SDK)
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxxxx\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@letto-ai.iam.gserviceaccount.com

# ─── Telegram Bot ───────────────────────────────
# Used for: Membership gating, deal broadcasting
# Create bot: message @BotFather on Telegram
TELEGRAM_BOT_TOKEN=xxxxx:xxxxx
TELEGRAM_PUBLIC_CHANNEL_ID=-100xxxxx  # @letto_live_deals
TELEGRAM_PREMIUM_CHANNEL_ID=-100xxxxx # @letto_live_premium

# ─── Kiwi.com Tequila ───────────────────────────
# Used for: Flight price scanning
# Register: https://tequila.kiwi.com/portal/register
KIWI_API_KEY=xxxxx

# ─── Travelpayouts (optional, additional flights source) ─
TRAVELPAYOUTS_API_KEY=xxxxx
TRAVELPAYOUTS_MARKER=xxxxx

# ─── Mailchimp / Substack (newsletter) ──────────
MAILCHIMP_API_KEY=xxxxx
MAILCHIMP_LIST_ID=xxxxx
MAILCHIMP_SERVER_PREFIX=usXX

# ─── n8n Webhook (for deal pipeline) ────────────
N8N_WEBHOOK_URL=https://n8n.paunov.tech/webhook/letto-deal-publish
N8N_WEBHOOK_SECRET=xxxxx

# ─── Public site config ─────────────────────────
VITE_SITE_URL=https://letto.live
VITE_PUBLIC_TELEGRAM_LINK=https://t.me/letto_ai_deals
VITE_CONTACT_EMAIL=info@letto.live

# ─── Feature flags ──────────────────────────────
VITE_ENABLE_AI_SEARCH=true
VITE_ENABLE_BETA_PRICING=true
